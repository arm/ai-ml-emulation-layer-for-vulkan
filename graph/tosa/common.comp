// BF16 <-> FP32 conversions (bf16 stored as the top 16 bits of IEEE754 fp32)
float decode_to_f32(bfloat16_t x)
{
    uint u = uint(x) << 16;
    return uintBitsToFloat(u);
}

float16_t decode_to_f16(float8_e5m2_t x)
{
    const uint packed = uint(x) << 8;
    return float16_t(unpackHalf2x16(packed).x);
}

float16_t decode_float8_e4m3_to_f16(float8_e4m3_t x)
{
    const uint sign = (uint(x) >> 7) & 0x1u;
    const uint exponent = (uint(x) >> 3) & 0xFu;
    const uint mantissa = uint(x) & 0x7u;

    if (exponent == 0xFu && mantissa == 0x7u) {
        return float16_t(NAN);
    }

    float value = 0.0;
    if (exponent == 0u) {
        value = (mantissa == 0u) ? 0.0 : float(mantissa) / 512.0;
    } else {
        value = exp2(float(int(exponent) - 7)) * (1.0 + float(mantissa) / 8.0);
    }

    return float16_t(sign != 0u ? -value : value);
}

float16_t decode_float8_to_f16(uint8_t x, uint typeTag)
{
    if (typeTag == TYPE_FLOAT8_E4M3) {
        return decode_float8_e4m3_to_f16(x);
    }
    return decode_to_f16(x);
}

float16_t decode_to_f16(bfloat16_t x)
{
    return float16_t(decode_to_f32(x));
}

float16_t decode_to_f16(float16_t x)
