// Decode a storage scalar into compute type.
#define DECODE_STORAGE_TO_COMP(rawValue, typeTag, compType)                                                           \
    ((typeTag) == TYPE_FLOAT8_E5M2 || (typeTag) == TYPE_FLOAT8_E4M3                                                   \
                            ? compType(decode_float8_to_f16(uint8_t(rawValue), typeTag))                              \
                        : ((IS_BFLOAT(typeTag)) ? compType(decode_to_f32(rawValue)) : compType(rawValue)))

// Encode a compute scalar into storage type with truncation semantics for bf16.
#define ENCODE_COMP_TO_STORAGE(compValue, storageType, typeTag)                                                       \
    ((typeTag) == TYPE_FLOAT8_E5M2 || (typeTag) == TYPE_FLOAT8_E4M3                                                   \
                            ? storageType(encode_from_f16_to_float8_trunc_by_type(float16_t(compValue), typeTag))    \
                        : ((IS_BFLOAT(typeTag))                                                                       \
                               ? storageType(encode_from_f32(float(compValue), storageType(0)))                      \
                               : storageType(compValue)))

// Encode a compute scalar into storage type with RNE semantics for bf16.
#define ENCODE_COMP_TO_STORAGE_RNE(compValue, storageType, typeTag)                                                   \
    ((typeTag) == TYPE_FLOAT8_E5M2 || (typeTag) == TYPE_FLOAT8_E4M3                                                   \
                            ? storageType(encode_from_f16_to_float8_rne_by_type(float16_t(compValue), typeTag))      \
                        : ((IS_BFLOAT(typeTag))                                                                       \
                               ? storageType(encode_from_f32_rne(float(compValue), storageType(0)))                  \
                               : storageType(compValue)))

// Shared conversion overloads for convolution-family shaders.
#define DEFINE_CONV_ACC_CASTS(ACC_TYPE, OUT_TYPE, IN_TYPE_TAG, OUT_TYPE_TAG)                                          \
    ACC_TYPE to_acc(float16_t v)  { return ACC_TYPE(v); }                                                             \
    ACC_TYPE to_acc(float v)      { return ACC_TYPE(v); }                                                             \
    ACC_TYPE to_acc(int8_t v)     { return ACC_TYPE(v); }                                                             \
    ACC_TYPE to_acc(int16_t v)    { return ACC_TYPE(v); }                                                             \
    ACC_TYPE to_acc(int v)        { return ACC_TYPE(v); }                                                             \
    ACC_TYPE to_acc(int64_t v)    { return ACC_TYPE(v); }                                                             \
    ACC_TYPE to_acc(bfloat16_t v) { return ACC_TYPE(decode_to_f32(v)); }                                              \
    ACC_TYPE to_acc(uint8_t v) { return ACC_TYPE(decode_float8_to_f16(v, IN_TYPE_TAG)); }                            \
                                                                                                                       \
    OUT_TYPE acc_to_out(ACC_TYPE v, bfloat16_t) { return OUT_TYPE(encode_from_f32(float(v), bfloat16_t(0))); }      \
    OUT_TYPE acc_to_out(ACC_TYPE v, uint8_t) { return OUT_TYPE(encode_from_f32_to_float8_trunc_by_type(float(v), OUT_TYPE_TAG)); }\
    OUT_TYPE acc_to_out(ACC_TYPE v, float16_t)  { return OUT_TYPE(v); }                                               \
    OUT_TYPE acc_to_out(ACC_TYPE v, float)      { return OUT_TYPE(v); }                                               \
    OUT_TYPE acc_to_out(ACC_TYPE v, int8_t)     { return OUT_TYPE(v); }                                               \
    OUT_TYPE acc_to_out(ACC_TYPE v, int16_t)    { return OUT_TYPE(v); }                                               \
    OUT_TYPE acc_to_out(ACC_TYPE v, int)        { return OUT_TYPE(v); }                                               \
    OUT_TYPE acc_to_out(ACC_TYPE v, int64_t)    { return OUT_TYPE(v); }

float tosa_min_nan_f32(float a, float b, uint nanMode)
{
    if (isnan(a)) {
        return (nanMode == NAN_MODE_PROPAGATE) ? a : b;
    }
    if (isnan(b)) {
        return (nanMode == NAN_MODE_PROPAGATE) ? b : a;
    }
    return min(a, b);
}

float tosa_max_nan_f32(float a, float b, uint nanMode)
{
    if (isnan(a)) {
        return (nanMode == NAN_MODE_PROPAGATE) ? a : b;
    }
    if (isnan(b)) {
        return (nanMode == NAN_MODE_PROPAGATE) ? b : a;
    }
    return max(a, b);
}
