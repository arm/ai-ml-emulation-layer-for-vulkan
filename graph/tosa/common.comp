#define TYPE_INT32 0x6934  // "i4"
#define TYPE_INT64 0x6938  // "i8"
#define TYPE_HALF 0x6632   // "f2"
#define TYPE_FLOAT 0x6634  // "f4"
#define TYPE_BFLOAT16 0x6642 // "fB"
#define TYPE_FLOAT8_E5M2 0x664D // "fM"
#define TYPE_FLOAT8_E4M3 0x664E // "fN"
#define TYPE_DOUBLE 0x6638 // "f8"

// Bfloat type
#define bfloat16_t uint16_t
#define float8_e4m3_t uint8_t
