// Truncation per rule: take top 16 bits of fp32
bfloat16_t encode_from_f32_trunc(float x)
{
    uint u = floatBitsToUint(x);
    return bfloat16_t(u >> 16);
}

bfloat16_t encode_from_f32_trunc(float x, bfloat16_t)
{
    return encode_from_f32_trunc(x);
}

float8_e5m2_t encode_from_f32_to_float8_e5m2_trunc(float x)
{
    uint sign = (floatBitsToUint(x) >> 24) & 0x80u;

    if (isnan(x)) {
        // Use a quiet NaN payload in e5m2 format.
        return float8_e5m2_t(sign | 0x7Du);
    }

    if (isinf(x) || x > 57344.0 || x < -57344.0) {
        return float8_e5m2_t(sign | 0x7Cu);
    }

    uint packed = packHalf2x16(vec2(x, 0.0));
    return float8_e5m2_t(packed >> 8);
}

float8_e4m3_t encode_from_f32_to_float8_e4m3_trunc(float x)
{
    uint sign = (floatBitsToUint(x) >> 24) & 0x80u;
    float ax = abs(x);

    if (isnan(x) || isinf(x) || ax > 448.0) {
        return float8_e4m3_t(sign | 0x7Fu);
    }

    if (ax == 0.0) {
        return float8_e4m3_t(sign);
    }

    // Subnormal region: value = mantissa * 2^-9 with mantissa in [1,7].
    if (ax < exp2(-6.0)) {
        uint mantissa = uint(clamp(roundEven(ax * 512.0), 0.0, 8.0));
        if (mantissa == 0u) {
            return float8_e4m3_t(sign);
        }
        if (mantissa >= 8u) {
            return float8_e4m3_t(sign | 0x08u); // Smallest normalized value.
        }
        return float8_e4m3_t(sign | mantissa);
    }

    int exponent = int(floor(log2(ax)));
    float scaled = ax * exp2(float(-exponent));
    uint mantissa = uint(clamp(roundEven((scaled - 1.0) * 8.0), 0.0, 8.0));
    if (mantissa == 8u) {
        mantissa = 0u;
        exponent += 1;
    }

    if (exponent > 8) {
        return float8_e4m3_t(sign | 0x7Fu);
    }

    uint exponentField = uint(exponent + 7);
    if (exponentField == 0xFu && mantissa == 0x7u) {
        mantissa = 0x6u; // Reserve 0x7F for NaN / non-finite encode path.
    }
    return float8_e4m3_t(sign | (exponentField << 3) | mantissa);
}

float8_e5m2_t encode_from_f32_trunc(float x, float8_e5m2_t)
{
    return encode_from_f32_to_float8_e5m2_trunc(x);
}

float8_e5m2_t encode_from_f16_trunc(float16_t x, float8_e5m2_t)
{
    uint packed = packHalf2x16(vec2(float(x), 0.0));
    return float8_e5m2_t(packed >> 8);
}

uint8_t encode_from_f32_to_float8_trunc_by_type(float x, uint typeTag)
{
    if (typeTag == TYPE_FLOAT8_E4M3) {
        return uint8_t(encode_from_f32_to_float8_e4m3_trunc(x));
    }
    return uint8_t(encode_from_f32_to_float8_e5m2_trunc(x));
}

uint8_t encode_from_f16_to_float8_trunc_by_type(float16_t x, uint typeTag)
{
    return encode_from_f32_to_float8_trunc_by_type(float(x), typeTag);
}

float16_t encode_from_f32_trunc(float x, float16_t)
{
    return float16_t(x);
}

// Round-to-nearest-even conversion with Inf/NaN handling preserved.
bfloat16_t f32_to_bf16_rne(float x)
{
    uint u = floatBitsToUint(x);
    uint exp = u & 0x7F800000u;
    uint mantissa = u & 0x007FFFFFu;

    if (exp == 0x7F800000u) {
        if (mantissa != 0u) {
            return bfloat16_t((u >> 16) | 0x0040u);
        }
        return bfloat16_t(u >> 16);
    }

    uint lsb = (u >> 16) & 1u;
    u += 0x7FFFu + lsb;
    return bfloat16_t(u >> 16);
}

bfloat16_t encode_from_f32_rne(float x)
{
    return f32_to_bf16_rne(x);
}

bfloat16_t encode_from_f32_rne(float x, bfloat16_t)
{
    return encode_from_f32_rne(x);
}

