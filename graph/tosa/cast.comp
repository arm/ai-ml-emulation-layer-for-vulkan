#define IN_T %in_t%
#define OUT_T %out_t%
#define TYPE_IN %in_t_type%
#define TYPE_OUT %out_t_type%
#define TYPE_IN_MIN %in_t_lowest%
#define TYPE_IN_MAX %in_t_max%
#define TYPE_OUT_MIN %out_t_lowest%
#define TYPE_OUT_MAX %out_t_max%

layout(local_size_x = %warpX%) in;

layout(constant_id = 0) const uint32_t RANK = RANK_MAX;

layout(set = 0, binding = 0) uniform tensorARM<OUT_T, RANK> outputData;
layout(set = 1, binding = 0) uniform tensorARM<IN_T, RANK> inputData;

void main() {
    uint[RANK] index;
    getIndex(outputData, index);

    IN_T value;
    tensorReadARM(inputData, index, value);

#if IS_BOOL(TYPE_OUT)
    #if IS_FLOAT8(TYPE_IN)
        OUT_T outValue = OUT_T(float(decode_float8_to_f16(uint8_t(value), TYPE_IN)) != 0.0);
    #elif IS_BFLOAT(TYPE_IN)
        OUT_T outValue = OUT_T(decode_to_f32(value) != 0.0);
    #else
        OUT_T outValue = OUT_T(value);
    #endif
#elif IS_BFLOAT(TYPE_OUT)
    #if IS_BOOL(TYPE_IN)
        OUT_T outValue = encode_from_f32_rne(value ? 1.0 : 0.0, OUT_T(0));
    #elif IS_FLOAT8(TYPE_IN)
        OUT_T outValue = encode_from_f32_rne(float(decode_float8_to_f16(uint8_t(value), TYPE_IN)), OUT_T(0));
    #elif IS_BFLOAT(TYPE_IN)
        OUT_T outValue = value;
    #else
        OUT_T outValue = encode_from_f32_rne(float(value), OUT_T(0));
    #endif
#elif IS_FLOAT8(TYPE_OUT)
    #if IS_BOOL(TYPE_IN)
        OUT_T outValue = OUT_T(encode_from_f16_to_float8_trunc_by_type(value ? float16_t(1.0) : float16_t(0.0), TYPE_OUT));
    #elif IS_FLOAT8(TYPE_IN)
        OUT_T outValue = OUT_T(encode_from_f16_to_float8_trunc_by_type(decode_float8_to_f16(uint8_t(value), TYPE_IN), TYPE_OUT));
    #elif IS_BFLOAT(TYPE_IN)
        OUT_T outValue = OUT_T(encode_from_f32_to_float8_trunc_by_type(decode_to_f32(value), TYPE_OUT));
    #else
        OUT_T outValue = OUT_T(encode_from_f32_to_float8_trunc_by_type(float(value), TYPE_OUT));
    #endif
#elif IS_FLOAT(TYPE_OUT)
    #if IS_BOOL(TYPE_IN)
        OUT_T outValue = OUT_T(value ? 1.0 : 0.0);
    #elif IS_FLOAT8(TYPE_IN)
        OUT_T outValue = OUT_T(decode_float8_to_f16(uint8_t(value), TYPE_IN));
    #elif IS_BFLOAT(TYPE_IN)
        OUT_T outValue = OUT_T(decode_to_f32(value));
    #else
        OUT_T outValue = OUT_T(0.0);
        if (TYPE_IN_MIN < TYPE_OUT_MIN && TYPE_IN_MAX > TYPE_OUT_MAX) {
            if (value > IN_T(TYPE_OUT_MAX)) {
                outValue = OUT_T(1.0 / 0.0); // +Inf
            } else if (value < IN_T(TYPE_OUT_MIN)) {
                outValue = OUT_T(-1.0 / 0.0); // -Inf
            } else {
                outValue = OUT_T(value);
            }
        } else {
            outValue = OUT_T(value);
        }
    #endif
#else // TYPE_OUT: Int
    #if IS_BOOL(TYPE_IN)
        OUT_T outValue = OUT_T(value ? 1 : 0);
    #elif IS_FLOAT(TYPE_IN)
        float fvalue = float(value);
    #elif IS_FLOAT8(TYPE_IN)
        float fvalue = float(decode_float8_to_f16(uint8_t(value), TYPE_IN));
    #elif IS_BFLOAT(TYPE_IN)
        float fvalue = decode_to_f32(value);
    #else
        OUT_T outValue = OUT_T(value);
    #endif
    #if IS_FLOAT(TYPE_IN) || IS_FLOAT8(TYPE_IN) || IS_BFLOAT(TYPE_IN)
        OUT_T outValue = OUT_T(0);
        if (fvalue <= float(TYPE_OUT_MIN)) {
            outValue = OUT_T(TYPE_OUT_MIN);
        } else if (fvalue >= float(TYPE_OUT_MAX)) {
            outValue = OUT_T(TYPE_OUT_MAX);
        } else {
            outValue = OUT_T(roundEven(fvalue));
        }
    #endif
#endif

    tensorWriteARM(outputData, index, outValue);
}
