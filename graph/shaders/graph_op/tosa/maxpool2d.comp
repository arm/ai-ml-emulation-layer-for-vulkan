#define STORAGE_T %in_out_t%
#define TYPE_IN_OUT %in_out_t_type%

#define IN_OUT_T %in_out_t_comp%

layout(local_size_x = %warpX%) in;

layout(push_constant) uniform PushConstants {
    int32_t kernel[2];
    int32_t stride[2];
    int32_t pad[4];
    uint nanMode;
} pushConstants;

layout(set = 0, binding = 0) uniform tensorARM<STORAGE_T, 4> outputData;
layout(set = 1, binding = 0) uniform tensorARM<STORAGE_T, 4> inputData;

void main() {
    uint[4] index;
    getIndex4(outputData, index);

    IN_OUT_T acc = IN_OUT_T(%in_out_t_lowest%);
    uint on = index[0];
    uint oy = index[1];
    uint ox = index[2];
    uint oc = index[3];

    // Keep math in signed domain for signed push constants and cast only after bounds checks.
    int kernelY = max(pushConstants.kernel[0], 0);
    int kernelX = max(pushConstants.kernel[1], 0);
    int strideY = max(pushConstants.stride[0], 1);
    int strideX = max(pushConstants.stride[1], 1);

    int iy = int(oy) * strideY - pushConstants.pad[0];
    int ix = int(ox) * strideX - pushConstants.pad[2];

    for (int ky = 0; ky < kernelY; ++ky) {
        for (int kx = 0; kx < kernelX; ++kx) {
            int y = iy + ky;
            int x = ix + kx;

            if (y >= 0 && x >= 0 && uint(y) < tensorSizeARM(inputData, 1) && uint(x) < tensorSizeARM(inputData, 2)) {
                STORAGE_T valueRaw;
                tensorReadARM(inputData, uint[](on, uint(y), uint(x), oc), valueRaw);

                IN_OUT_T value = DECODE_STORAGE_TO_COMP(valueRaw, TYPE_IN_OUT, IN_OUT_T);

#if IS_FLOAT(TYPE_IN_OUT) || IS_REDUCED_FLOAT(TYPE_IN_OUT)
                if (isnan(value)) {
                    if (pushConstants.nanMode == NAN_MODE_IGNORE) {
                        // Ignore value and continue
                        continue;
                    }
                    else {
                        // If any value is NaN, then the result must be NaN
                        tensorWriteARM(outputData, index, ENCODE_COMP_TO_STORAGE(value, STORAGE_T, TYPE_IN_OUT));
                        return;
                    }
                }
#endif
                acc = max(acc, value);
            }
        }
    }

    tensorWriteARM(outputData, index, ENCODE_COMP_TO_STORAGE(acc, STORAGE_T, TYPE_IN_OUT));
}
