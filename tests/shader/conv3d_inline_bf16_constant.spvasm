               OpCapability VulkanMemoryModel
               OpCapability Shader
               OpCapability Int8
               OpCapability TensorsARM
               OpCapability GraphARM
               OpCapability ReplicatedCompositesEXT
               OpCapability BFloat16TypeKHR
               OpExtension "SPV_ARM_tensors"
               OpExtension "SPV_ARM_graph"
               OpExtension "SPV_EXT_replicated_composites"
               OpExtension "SPV_KHR_bfloat16"
               OpExtension "SPV_KHR_vulkan_memory_model"
       %tosa = OpExtInstImport "TOSA.001000.1"
               OpMemoryModel Logical Vulkan
               OpName %input_var "input_var"
               OpName %output_var "output_var"
               OpDecorate %input_var Binding 0
               OpDecorate %input_var DescriptorSet 0
               OpDecorate %output_var Binding 1
               OpDecorate %output_var DescriptorSet 0
       %bf16 = OpTypeFloat 16 BFloat16KHR
       %uint = OpTypeInt 32 0
      %uchar = OpTypeInt 8 0
       %bool = OpTypeBool
     %uint_0 = OpConstant %uint 0
     %uint_1 = OpConstant %uint 1
     %uint_3 = OpConstant %uint 3
     %uint_5 = OpConstant %uint 5
     %uint_6 = OpConstant %uint 6
    %uchar_0 = OpConstant %uchar 0
      %false = OpConstantFalse %bool
   %bf16_one = OpConstant %bf16 1.0
%shape_rank_1 = OpTypeArray %uint %uint_1
%shape_rank_3 = OpTypeArray %uint %uint_3
%shape_rank_5 = OpTypeArray %uint %uint_5
%input_shape = OpConstantComposite %shape_rank_5 %uint_1 %uint_1 %uint_1 %uint_1 %uint_1
%input_tensor = OpTypeTensorARM %bf16 %uint_5 %input_shape
%ptr_input_tensor = OpTypePointer UniformConstant %input_tensor
  %input_var = OpVariable %ptr_input_tensor UniformConstant
%output_shape = OpConstantComposite %shape_rank_5 %uint_1 %uint_1 %uint_1 %uint_1 %uint_1
%output_tensor = OpTypeTensorARM %bf16 %uint_5 %output_shape
%ptr_output_tensor = OpTypePointer UniformConstant %output_tensor
 %output_var = OpVariable %ptr_output_tensor UniformConstant
%graph_type = OpTypeGraphARM 1 %input_tensor %output_tensor
%weight_shape = OpConstantComposite %shape_rank_5 %uint_1 %uint_1 %uint_1 %uint_1 %uint_1
%weight_tensor = OpTypeTensorARM %bf16 %uint_5 %weight_shape
%weight_const = OpConstantCompositeReplicateEXT %weight_tensor %bf16_one
%bias_shape = OpConstantComposite %shape_rank_1 %uint_1
%bias_tensor = OpTypeTensorARM %bf16 %uint_1 %bias_shape
%bias_const = OpConstantCompositeReplicateEXT %bias_tensor %bf16_one
%zero_point_tensor = OpTypeTensorARM %uchar %uint_1 %bias_shape
%zero_point = OpConstantComposite %zero_point_tensor %uchar_0
%vec3_shape = OpConstantComposite %shape_rank_1 %uint_3
%vec3_tensor = OpTypeTensorARM %uint %uint_1 %vec3_shape
%stride = OpConstantCompositeReplicateEXT %vec3_tensor %uint_1
%dilation = OpConstantCompositeReplicateEXT %vec3_tensor %uint_1
%pad_shape = OpConstantComposite %shape_rank_1 %uint_6
%pad_tensor = OpTypeTensorARM %uint %uint_1 %pad_shape
%pad = OpConstantCompositeReplicateEXT %pad_tensor %uint_0
               OpGraphEntryPointARM %graph "conv3d_inline_bf16_constant" %input_var %output_var
      %graph = OpGraphARM %graph_type
 %input = OpGraphInputARM %input_tensor %uint_0
 %output = OpExtInst %output_tensor %tosa CONV3D %pad %stride %dilation %uint_1 %false %input %weight_const %bias_const %zero_point %zero_point
               OpGraphSetOutputARM %output %uint_0
               OpGraphEndARM
